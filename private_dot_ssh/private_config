ForwardAgent yes
Compression yes
ForwardX11 yes
HashKnownHosts no
GSSAPIDelegateCredentials yes

ServerAliveInterval 60

Host *
    AddKeysToAgent yes
    ControlMaster auto
    ControlPath ~/.ssh/master-%r@%h:%p
    ServerAliveInterval 60
    ServerAliveCountMax 5
    HostKeyAlgorithms +ssh-rsa
    PubkeyAcceptedKeyTypes +ssh-rsa

Include ~/.ssh/config.customer
